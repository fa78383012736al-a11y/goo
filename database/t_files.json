    "name": "keyboard_ripple_effect (1)",
    "keywords": "",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Keyboard Ripple Effect</title>\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #f0f0f0;\n            margin: 0;\n            font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n        }\n\n        .keyboard {\n            display: flex;\n            gap: 20px;\n        }\n\n        .key {\n            position: relative;\n            width: 100px;\n            height: 100px;\n            background: #ffffff;\n            border-radius: 15px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 24px;\n            font-weight: bold;\n            color: #333;\n            cursor: pointer;\n            overflow: hidden;\n            user-select: none;\n            box-shadow: \n                0 10px 0 #dcdcdc,\n                0 15px 20px rgba(0,0,0,0.1);\n            transition: all 0.1s ease;\n        }\n\n        .key:active {\n            transform: translateY(8px);\n            box-shadow: \n                0 2px 0 #dcdcdc,\n                0 5px 10px rgba(0,0,0,0.1);\n        }\n\n        .key .icon {\n            font-size: 32px;\n            margin-bottom: 5px;\n        }\n\n        .ripple {\n            position: absolute;\n            background: rgba(0, 0, 0, 0.1);\n            transform: scale(0);\n            border-radius: 50%;\n            pointer-events: none;\n            animation: ripple-animation 0.6s linear;\n        }\n\n        @keyframes ripple-animation {\n            to {\n                transform: scale(4);\n                opacity: 0;\n            }\n        }\n\n        .label {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        .label span {\n            font-size: 12px;\n            text-transform: uppercase;\n            color: #888;\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"keyboard\">\n        <div class=\"key\" onclick=\"createRipple(event)\">\n            <div class=\"label\">\n                <span style=\"font-size: 24px;\">⌘</span>\n                <span>command</span>\n            </div>\n        </div>\n        <div class=\"key\" onclick=\"createRipple(event)\">\n            <div class=\"label\">\n                <span style=\"font-size: 32px;\">Z</span>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        function createRipple(event) {\n            const key = event.currentTarget;\n            const circle = document.createElement(\"span\");\n            const diameter = Math.max(key.clientWidth, key.clientHeight);\n            const radius = diameter / 2;\n\n            circle.style.width = circle.style.height = `${diameter}px`;\n            circle.style.left = `${event.clientX - key.offsetLeft - radius}px`;\n            circle.style.top = `${event.clientY - key.offsetTop - radius}px`;\n            circle.classList.add(\"ripple\");\n\n            const ripple = key.getElementsByClassName(\"ripple\")[0];\n            if (ripple) {\n                ripple.remove();\n            }\n\n            key.appendChild(circle);\n        }\n    </script>\n</body>\n</html>\n",
