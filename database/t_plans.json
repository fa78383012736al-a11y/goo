    "name": "خطة_نشاط_لاصفية (2)",
    "keywords": "",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>سجل الأنشطة اللاصفية - JSON متكامل (جداول ديناميكية كاملة)</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --primary-purple: #5a2d7a;\n            --accent-green: #3d4d1d;\n            --bg-gradient: linear-gradient(135deg, #f8f9fb 0%, #f0f2f5 100%);\n            --card-bg: rgba(255, 255, 255, 0.95);\n            --border-gold: #c5a059;\n            --text-dark: #2c3e50;\n        }\n\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        body {\n            font-family: 'Cairo', sans-serif;\n            background: #cbd3da;\n            color: var(--text-dark);\n            -webkit-print-color-adjust: exact !important;\n            print-color-adjust: exact !important;\n        }\n\n        .page {\n            width: 210mm;\n            height: 297mm;\n            padding: 8mm;\n            margin: 10mm auto;\n            background: var(--bg-gradient);\n            box-shadow: 0 0 20px rgba(0,0,0,0.2);\n            position: relative;\n            overflow: visible;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            border: 12px solid transparent;\n            border-image: url('https://www.transparenttextures.com/patterns/gold-glitter.png') 30 stretch;\n            outline: 1.5px solid var(--border-gold);\n            outline-offset: -8px;\n            page-break-after: always;\n            break-after: page;\n            -webkit-print-color-adjust: exact !important;\n            print-color-adjust: exact !important;\n            box-sizing: border-box;\n        }\n\n        .flex-content {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            min-height: 0;\n        }\n\n        .page-footer {\n            margin-top: auto;\n            width: 100%;\n            flex-shrink: 0;\n        }\n\n        table, .signature-section, .week-info-bar, .content-box, .separator-inner, .cover-details, .page-footer {\n            break-inside: avoid !important;\n            page-break-inside: avoid !important;\n        }\n\n        table {\n            width: 100%;\n            border-collapse: separate;\n            border-spacing: 0;\n            border-radius: 10px;\n            overflow: hidden;\n            border: 1px solid var(--border-gold);\n            margin: 5px 0;\n            table-layout: fixed;\n            empty-cells: show;\n            -webkit-print-color-adjust: exact !important;\n            print-color-adjust: exact !important;\n        }\n\n        th, td {\n            word-wrap: break-word;\n            overflow-wrap: break-word;\n            -webkit-print-color-adjust: exact !important;\n            print-color-adjust: exact !important;\n        }\n\n        th {\n            background: var(--primary-purple);\n            color: white;\n            padding: 8px;\n            font-size: 13px;\n        }\n\n        td {\n            background: white;\n            padding: 6px;\n            border: 0.5px solid #eee;\n            text-align: center;\n            font-size: 12px;\n            vertical-align: middle;\n        }\n\n        .day-header-cell {\n            background: var(--accent-green) !important;\n            color: white;\n            font-weight: bold;\n            width: 65px;\n            -webkit-print-color-adjust: exact !important;\n            print-color-adjust: exact !important;\n        }\n\n        .activity-type-cell {\n            background: #f8f9fa !important;\n            font-weight: bold;\n            width: 85px;\n            color: var(--primary-purple);\n            -webkit-print-color-adjust: exact !important;\n            print-color-adjust: exact !important;\n        }\n\n        .week-info-bar {\n            display: flex;\n            background: var(--card-bg);\n            border: 1.5px solid var(--border-gold);\n            border-radius: 8px;\n            margin-bottom: 10px;\n            overflow: hidden;\n            flex-shrink: 0;\n        }\n\n        .week-info-date {\n            flex: 2;\n            padding: 8px;\n            text-align: center;\n            font-weight: bold;\n            font-size: 15px;\n            background: #fdfbf7;\n        }\n\n        .week-info-label {\n            flex: 1;\n            padding: 8px;\n            background: var(--primary-purple);\n            color: white;\n            text-align: center;\n            font-weight: 900;\n            font-size: 18px;\n        }\n\n        h1.page-title {\n            font-size: 30px;\n            color: var(--primary-purple);\n            text-align: center;\n            margin: 10px 0 20px 0;\n            flex-shrink: 0;\n        }\n\n        .content-box {\n            background: var(--card-bg);\n            padding: 20px;\n            border-radius: 12px;\n            border: 1px solid rgba(197, 160, 89, 0.2);\n            margin-bottom: 15px;\n            line-height: 1.7;\n            font-size: 17px;\n        }\n\n        .highlight-title {\n            background: var(--primary-purple);\n            color: white;\n            padding: 4px 18px;\n            border-radius: 20px;\n            display: inline-block;\n            margin-bottom: 10px;\n            font-weight: bold;\n            font-size: 15px;\n        }\n\n        .separator-page {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background: linear-gradient(135deg, #5a2d7a 0%, #3d4d1d 100%);\n        }\n\n        .separator-inner {\n            text-align: center;\n            color: white;\n            border: 3px solid var(--border-gold);\n            padding: 40px;\n            border-radius: 25px;\n            background: rgba(0,0,0,0.2);\n        }\n\n        .cover-content {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 20px;\n            background: rgba(255, 255, 255, 0.3);\n            border-radius: 20px;\n        }\n\n        .cover-logo { width: 160px; height: 160px; margin-bottom: 30px; }\n        .cover-main-title { font-size: 48px; font-weight: 900; color: var(--primary-purple); text-shadow: 1px 1px 2px rgba(0,0,0,0.1); }\n        .cover-sub-title { font-size: 26px; font-weight: 600; color: var(--accent-green); margin-bottom: 40px; }\n        .cover-details { width: 90%; background: var(--card-bg); padding: 25px; border-radius: 12px; border-right: 8px solid var(--border-gold); box-shadow: 0 5px 20px rgba(0,0,0,0.05); }\n        .cover-details p { font-size: 19px; margin: 12px 0; border-bottom: 1px dashed #ddd; padding-bottom: 5px; display: flex; justify-content: space-between; }\n        .cover-details span { font-weight: bold; color: var(--primary-purple); }\n\n        .footer-border {\n            height: 40px;\n            background: linear-gradient(to top, rgba(197, 160, 89, 0.2), transparent);\n            border-top: 1px solid rgba(197, 160, 89, 0.3);\n        }\n\n        .signature-section {\n            display: flex;\n            justify-content: space-around;\n            font-weight: bold;\n            font-size: 13px;\n            color: var(--primary-purple);\n            padding: 8px 0 4px;\n        }\n\n        .json-panel-container {\n            max-width: 1100px;\n            margin: 20px auto 10px;\n            background: white;\n            border-radius: 24px;\n            padding: 18px 22px;\n            border: 2px solid var(--border-gold);\n            box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n        }\n        .json-panel-container h3 { color: var(--primary-purple); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }\n        .json-area { width: 100%; height: 200px; font-family: 'Cairo', monospace; font-size: 13px; padding: 12px; border: 1.5px solid #bdd3e6; border-radius: 14px; background: #fbfdff; direction: ltr; text-align: left; margin: 10px 0; resize: vertical; }\n        .btn { background: var(--primary-purple); color: white; border: none; padding: 10px 24px; border-radius: 50px; font-weight: 700; font-size: 14px; font-family: 'Cairo'; cursor: pointer; margin: 5px; display: inline-flex; align-items: center; gap: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); transition: 0.15s; }\n        .btn:hover { background: #46206a; }\n        .btn-outline { background: #f0f7fc; color: var(--primary-purple); border: 1.5px solid var(--primary-purple); }\n        .btn-copy { background: #d97706; color: white; border: none; padding: 10px 24px; border-radius: 50px; font-weight: 700; font-size: 14px; font-family: 'Cairo'; cursor: pointer; margin: 5px; display: inline-flex; align-items: center; gap: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); transition: 0.15s; }\n        .btn-copy:hover { background: #b45309; }\n\n        .header-upload-container { max-width: 1100px; margin: 0 auto 10px; background: white; padding: 12px 20px; border-radius: 16px; border: 2px solid var(--border-gold); display: flex; align-items: center; gap: 15px; flex-wrap: wrap; }\n        .header-upload-container p { font-weight: bold; color: var(--primary-purple); margin: 0; }\n        .image-uploader { width: 100%; height: 100%; border: 2px dashed var(--border-gold); background: rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center; position: relative; cursor: pointer; border-radius: 8px; overflow: hidden; }\n        .image-uploader input[type=\"file\"] { position: absolute; width: 100%; height: 100%; opacity: 0; cursor: pointer; }\n        .image-uploader img { max-width: 100%; max-height: 100%; object-fit: contain; display: none; }\n        .upload-prompt { text-align: center; color: var(--border-gold); font-weight: bold; font-size: 14px; }\n\n        .global-header-display { width: 100%; height: 120px; margin-bottom: 10px; display: none; border-bottom: 2px solid var(--border-gold); flex-shrink: 0; }\n        .global-header-display img { width: 100%; height: 100%; object-fit: fill; border-top-left-radius: 20px; border-top-right-radius: 20px; }\n\n        @media print {\n            @page { size: A4; margin: 0; }\n            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n            body { background: white; padding: 0; margin: 0; font-size: 12pt; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n            .page { margin: 0 auto; box-shadow: 0 0 20px rgba(0,0,0,0.2) !important; border: 12px solid transparent !important; border-image: url('https://www.transparenttextures.com/patterns/gold-glitter.png') 30 stretch !important; outline: 1.5px solid var(--border-gold) !important; page-break-after: always; break-after: page; background: var(--bg-gradient) !important; font-size: 9pt; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n            .no-print, .json-panel-container, .header-upload-container { display: none !important; }\n            table { font-size: 7pt; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n            td, th { padding: 2pt; word-wrap: break-word; overflow-wrap: break-word; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n            .day-header-cell, .activity-type-cell, .week-info-date, .week-info-label, .highlight-title, .separator-page, .separator-inner, .cover-content, .cover-details, .content-box, .footer-border, .signature-section, .global-header-display, .image-uploader, .btn, .btn-outline { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"json-panel-container no-print\">\n    <h3>🧩 بيانات JSON للقالب <span style=\"font-size:13px;background:var(--primary-purple);color:white;padding:2px 14px;border-radius:50px;\">سجل الأنشطة</span></h3>\n    <textarea id=\"jsonInput\" class=\"json-area\" placeholder=\"الصق JSON هنا ...\"></textarea>\n    <div style=\"display:flex; flex-wrap:wrap; gap:8px; align-items:center;\">\n        <button class=\"btn\" id=\"applyBtn\">✨ تطبيق البيانات وبناء السجل</button>\n        <button class=\"btn btn-outline\" id=\"loadDefaultBtn\">📚 تحميل الافتراضي</button>\n        <button class=\"btn btn-outline\" onclick=\"window.print()\">🖨️ طباعة السجل</button>\n        <button class=\"btn-copy\" id=\"copyRequestBtn\"><i class=\"fas fa-copy\"></i> نسخ رسالة الطلب</button>\n    </div>\n</div>\n\n<div class=\"header-upload-container no-print\">\n    <p>📷 رفع ترويسة موحدة لجميع الصفحات:</p>\n    <div class=\"image-uploader\" style=\"width:120px; height:50px;\">\n        <input type=\"file\" accept=\"image/*\" onchange=\"uploadGlobalHeader(this)\">\n        <div class=\"upload-prompt\" id=\"global-prompt\">اختر الترويسة</div>\n    </div>\n</div>\n\n<div id=\"report-container\"></div>\n\n<script>\n    const DEFAULT_JSON = {\n        schoolName: \"متوسطة بلسمر\",\n        activityLeader: \"عبدالرحمن مبارك الأسمري\",\n        principal: \"سعيد بن محمد الأسمري\",\n        educationDept: \"إدارة تعليم عسير\",\n        semester: \"الفصل الدراسي الثاني\",\n        year: \"1447 هـ\",\n        cover: {\n            mainTitle: \"سجل الأنشطة اللاصفية\",\n            subTitle: \"الفصل الدراسي الثاني - 1447 هـ\"\n        },\n        basmalaPage: true,\n        index: [\n            { number: 1, title: \"المقدمة\", page: 1 },\n            { number: 2, title: \"تعريف النشاط اللاصفي\", page: 2 },\n            { number: 3, title: \"أهمية النشاط اللاصفي\", page: 3 },\n            { number: 4, title: \"الرؤية والرسالة والقيم\", page: 4 },\n            { number: 5, title: \"الهدف العام للأنشطة\", page: 5 },\n            { number: 6, title: \"برامج الأنشطة اللاصفية\", page: 6 },\n            { number: 7, title: \"خطة الأنشطة (جداول الأسابيع)\", page: 7 }\n        ],\n        introduction: \"الحمد لله رب العالمين، والصلاة والسلام على أشرف الأنبياء والمرسلين، نبينا محمد وعلى آله وصحبه أجمعين.. أما بعد:\\nتعد الأنشطة اللاصفية ركيزة أساسية في العملية التعليمية والتربوية، فهي الميدان الخصب الذي يتيح للطالبة فرصة اكتشاف مواهبها وتنمية قدراتها، وصقل شخصيتها في إطار تربوي هادف. إن هذا السجل يمثل خارطة طريق لبرامجنا وأنشطتنا خلال الفصل الدراسي الثاني لعام 1447 هـ، والتي نسعى من خلالها إلى تقديم مزيج من الفائدة والمتعة، بما يتوافق مع رؤية المملكة 2030 في بناء جيل طموح ومبدع.\",\n        definition: {\n            concept: \"هو مجموعة من البرامج والفعاليات التي تمارسها الطالبة خارج نطاق المنهج الدراسي الرسمي، سواء داخل المدرسة أو خارجها، تحت إشراف تربوي، بهدف تحقيق أهداف تربوية محددة.\",\n            characteristics: [\n                \"الاختيارية والميل الشخصي للطالبة.\",\n                \"المرونة العالية في التنفيذ والزمان والمكان.\",\n                \"التركيز على الممارسة العملية والتعلم بالتجربة.\"\n            ]\n        },\n        importance: [\n            \"تعزيز القيم الوطنية: ترسيخ الانتماء والولاء للوطن.\",\n            \"بناء الشخصية: تنمية الثقة بالنفس، وتحمل المسؤولية.\",\n            \"اكتشاف الموهبة: التعرف على المبدعات وتطوير مهاراتهن.\",\n            \"الذكاء الاجتماعي: التدريب على العمل الجماعي.\"\n        ],\n        vision: \"الريادة في تقديم أنشطة طلابية مبتكرة تبني شخصية الطالبة وتنمي مواهبها.\",\n        mission: \"توفير بيئة تربوية محفزة من خلال برامج نوعية تتسم بالجودة والتنوع.\",\n        generalGoal: \"تحقيق النمو المتكامل لشخصية الطالبة تربوياً، واجتماعياً، ونفسياً، وعقلياً.\",\n        programs: [\n            { field: \"الثقافي\", examples: \"مسابقات الإلقاء، المسرح.\" },\n            { field: \"الفني\", examples: \"الرسم، الخط العربي.\" },\n            { field: \"العلمي\", examples: \"نادي الابتكار، الروبوت.\" }\n        ],\n        weeks: [\n            { week: \"الأول\", range: \"29/07/1447 إلى 03/08/1447\", days: [\"29/07/1447\",\"30/07/1447\",\"01/08/1447\",\"02/08/1447\",\"03/08/1447\"],\n              rows: [\n                { program: \"التعارف والتعريف بالأنشطة\", duration: \"20 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"مسابقة ثقافية سريعة\", duration: \"15 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"تدريب على الإلقاء\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الثاني\", range: \"06/08/1447 إلى 10/08/1447\", days: [\"06/08/1447\",\"07/08/1447\",\"08/08/1447\",\"09/08/1447\",\"10/08/1447\"],\n              rows: [\n                { program: \"محاضرة عن الأخلاق\", duration: \"20 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"ورشة رسم حر\", duration: \"15 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"تمرين الاسترخاء\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الثالث\", range: \"13/08/1447 إلى 17/08/1447\", days: [\"13/08/1447\",\"14/08/1447\",\"15/08/1447\",\"16/08/1447\",\"17/08/1447\"],\n              rows: [\n                { program: \"مسابقة القرآن الكريم\", duration: \"20 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"نادي القراءة\", duration: \"15 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"تدريب على الحوار\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الرابع\", range: \"20/08/1447 إلى 24/08/1447\", days: [\"20/08/1447\",\"21/08/1447\",\"22/08/1447\",\"23/08/1447\",\"24/08/1447\"],\n              rows: [\n                { program: \"دورة الإسعافات الأولية\", duration: \"20 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"بطولة الشطرنج\", duration: \"15 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"تمرين التأمل\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الخامس\", range: \"27/08/1447 إلى 02/09/1447\", days: [\"27/08/1447\",\"28/08/1447\",\"29/08/1447\",\"01/09/1447\",\"02/09/1447\"],\n              rows: [\n                { program: \"محاضرة عن الوسطية\", duration: \"20 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"ورشة الخط العربي\", duration: \"15 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"تدريب القيادة\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"السادس\", range: \"05/09/1447 إلى 09/09/1447\", days: [\"05/09/1447\",\"06/09/1447\",\"07/09/1447\",\"08/09/1447\",\"09/09/1447\"],\n              rows: [\n                { program: \"ندوة عن التنمر\", duration: \"20 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"مسابقة الرسم\", duration: \"15 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"تمرين التركيز\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"السابع\", range: \"12/09/1447 إلى 16/09/1447\", days: [\"12/09/1447\",\"13/09/1447\",\"14/09/1447\",\"15/09/1447\",\"16/09/1447\"],\n              rows: [\n                { program: \"برنامج تكريم المتفوقات\", duration: \"20 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"يوم مفتوح\", duration: \"15 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"تدريب العمل الجماعي\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الثامن\", range: \"10/10/1447 إلى 14/10/1447\", days: [\"10/10/1447\",\"11/10/1447\",\"12/10/1447\",\"13/10/1447\",\"14/10/1447\"],\n              rows: [\n                { program: \"أسبوع الموهبة\", duration: \"20 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"معرض فني\", duration: \"15 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"تمرين التنفس\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"التاسع\", range: \"17/10/1447 إلى 21/10/1447\", days: [\"17/10/1447\",\"18/10/1447\",\"19/10/1447\",\"20/10/1447\",\"21/10/1447\"],\n              rows: [\n                { program: \"دورة الحاسب الآلي\", duration: \"20 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"بطولة الألعاب الإلكترونية\", duration: \"15 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"تدريب حل المشكلات\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"العاشر\", range: \"24/10/1447 إلى 28/10/1447\", days: [\"24/10/1447\",\"25/10/1447\",\"26/10/1447\",\"27/10/1447\",\"28/10/1447\"],\n              rows: [\n                { program: \"محاضرة عن الصحة النفسية\", duration: \"20 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"نادي المناظرات\", duration: \"15 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"تمرين المرونة\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الحادي عشر\", range: \"02/11/1447 إلى 06/11/1447\", days: [\"02/11/1447\",\"03/11/1447\",\"04/11/1447\",\"05/11/1447\",\"06/11/1447\"],\n              rows: [\n                { program: \"حملة النظافة\", duration: \"20 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"ورشة إعادة التدوير\", duration: \"15 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"تدريب التعاون\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الثاني عشر\", range: \"09/11/1447 إلى 13/11/1447\", days: [\"09/11/1447\",\"10/11/1447\",\"11/11/1447\",\"12/11/1447\",\"13/11/1447\"],\n              rows: [\n                { program: \"برنامج رحلة افتراضية\", duration: \"20 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"مسابقة التصوير\", duration: \"15 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"تمرين التخيل\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الثالث عشر\", range: \"16/11/1447 إلى 20/11/1447\", days: [\"16/11/1447\",\"17/11/1447\",\"18/11/1447\",\"19/11/1447\",\"20/11/1447\"],\n              rows: [\n                { program: \"ندوة ريادة الأعمال\", duration: \"20 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"سوق خيري\", duration: \"15 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"تدريب الإدارة المالية\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الرابع عشر\", range: \"23/11/1447 إلى 27/11/1447\", days: [\"23/11/1447\",\"24/11/1447\",\"25/11/1447\",\"26/11/1447\",\"27/11/1447\"],\n              rows: [\n                { program: \"أسبوع المرور\", duration: \"20 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"مسابقة السلامة\", duration: \"15 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"تمرين الانتباه\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الخامس عشر\", range: \"30/11/1447 إلى 04/12/1447\", days: [\"30/11/1447\",\"01/12/1447\",\"02/12/1447\",\"03/12/1447\",\"04/12/1447\"],\n              rows: [\n                { program: \"اليوم الوطني\", duration: \"20 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"أوبريت وطني\", duration: \"15 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"تدريب الانتماء\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"السادس عشر\", range: \"14/12/1447 إلى 18/12/1447\", days: [\"14/12/1447\",\"15/12/1447\",\"16/12/1447\",\"17/12/1447\",\"18/12/1447\"],\n              rows: [\n                { program: \"مسابقة العلوم\", duration: \"20 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"معرض اختراعات\", duration: \"15 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"تدريب التفكير الإبداعي\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"السابع عشر\", range: \"21/12/1447 إلى 25/12/1447\", days: [\"21/12/1447\",\"22/12/1447\",\"23/12/1447\",\"24/12/1447\",\"25/12/1447\"],\n              rows: [\n                { program: \"حفل الختام\", duration: \"20 دقيقة\", implementer: \"أ. نورة الشهراني\" },\n                { program: \"تكريم المشاركات\", duration: \"15 دقيقة\", implementer: \"أ. منيرة القحطاني\" },\n                { program: \"كلمة الوداع\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]},\n            { week: \"الثامن عشر\", range: \"28/12/1447 إلى 03/01/1448\", days: [\"28/12/1447\",\"29/12/1447\",\"01/01/1448\",\"02/01/1448\",\"03/01/1448\"],\n              rows: [\n                { program: \"توزيع الشهادات\", duration: \"20 دقيقة\", implementer: \"أ. منال الشمري\" },\n                { program: \"حفل شاي\", duration: \"15 دقيقة\", implementer: \"أ. هند القحطاني\" },\n                { program: \"تمرين الامتنان\", duration: \"10 دقائق\", implementer: \"أ. عائشة العمري\" }\n              ]}\n        ]\n    };\n\n    const container = document.getElementById('report-container');\n    const jsonArea = document.getElementById('jsonInput');\n    const dayNames = [\"الأحد\", \"الاثنين\", \"الثلاثاء\", \"الأربعاء\", \"الخميس\"];\n\n    // رسالة الطلب النصية\n    const requestMessage = `فضلاً تعبئة البيانات التالية لإعداد خطة النشاط اللاصفي:\n\nبيانات المدرسة:\n\n- اسم المدرسة:\n- المرحلة الدراسية:\n- إدارة التعليم:\n- اسم قائد/قائدة المدرسة:\n- اسم رائد/رائدة النشاط:\n\nمجالات النشاط الموجودة في المدرسة:\n(ثقافي - علمي - رياضي - فني - تقني - اجتماعي - غيرها)\n\nبيانات البرامج المنفذة خلال الأسبوع:\n\n- وقت التنفيذ:\n- اسم البرنامج:\n- مدة التنفيذ:\n- اسم المنفذ/المنفذة:`;\n\n    // دالة نسخ رسالة الطلب\n    function copyRequestMessage() {\n        navigator.clipboard.writeText(requestMessage).then(() => {\n            const btn = document.getElementById('copyRequestBtn');\n            const originalHTML = btn.innerHTML;\n            btn.innerHTML = '<i class=\"fas fa-check\"></i> تم النسخ';\n            btn.style.background = '#16a34a';\n            setTimeout(() => {\n                btn.innerHTML = originalHTML;\n                btn.style.background = '#d97706';\n            }, 2000);\n        }).catch(() => {\n            alert('تعذر نسخ النص، يرجى نسخه يدوياً');\n        });\n    }\n\n    document.getElementById('copyRequestBtn').addEventListener('click', copyRequestMessage);\n\n    function buildReport(data) {\n        container.innerHTML = '';\n\n        // صفحة الغلاف\n        const coverPage = document.createElement('div');\n        coverPage.className = 'page';\n        coverPage.innerHTML = `\n            <div class=\"cover-content flex-content\">\n                <div class=\"cover-logo\">\n                    <div class=\"image-uploader\">\n                        <input type=\"file\" accept=\"image/*\" onchange=\"previewLocalImage(this)\">\n                        <div class=\"upload-prompt\">انقر لإدراج<br>شعار المدرسة</div>\n                        <img src=\"\" alt=\"Logo\">\n                    </div>\n                </div>\n                <h1 class=\"cover-main-title\">${escapeHTML(data.cover.mainTitle)}</h1>\n                <h2 class=\"cover-sub-title\">${escapeHTML(data.cover.subTitle)}</h2>\n                <div class=\"cover-details\">\n                    <p>المدرسة: <span>${escapeHTML(data.schoolName)}</span></p>\n                    <p>إعداد رائدة النشاط: <span>${escapeHTML(data.activityLeader)}</span></p>\n                    <p>مديرة المدرسة: <span>${escapeHTML(data.principal)}</span></p>\n                    <p>إدارة التعليم: <span>${escapeHTML(data.educationDept)}</span></p>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(coverPage);\n\n        if (data.basmalaPage) {\n            const basmalaPage = createPageWithHeader();\n            basmalaPage.innerHTML += `\n                <div class=\"flex-content\" style=\"justify-content:center; align-items:center;\">\n                    <div style=\"width:80%; height:300px; background:white; padding:20px; border-radius:15px; border:2px solid var(--border-gold);\">\n                        <div class=\"image-uploader\" style=\"height:100%;\">\n                            <input type=\"file\" accept=\"image/*\" onchange=\"previewLocalImage(this)\">\n                            <div class=\"upload-prompt\">انقر لإدراج صورة<br>(بسم الله الرحمن الرحيم)</div>\n                            <img src=\"\" alt=\"Basmala\">\n                        </div>\n                    </div>\n                </div>\n                <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n            `;\n            container.appendChild(basmalaPage);\n        }\n\n        const indexPage = createPageWithHeader();\n        let indexRows = '';\n        data.index.forEach(item => {\n            indexRows += `<tr><td>${item.number}</td><td>${escapeHTML(item.title)}</td><td>${item.page}</td></tr>`;\n        });\n        indexPage.innerHTML += `\n            <h1 class=\"page-title\">فهرس المحتويات</h1>\n            <div class=\"flex-content\">\n                <div class=\"content-box\" style=\"padding:0; overflow:hidden;\">\n                    <table>\n                        <thead><tr><th style=\"width:15%;\">م</th><th>المحتوى</th><th style=\"width:20%;\">الصفحة</th></tr></thead>\n                        <tbody>${indexRows}</tbody>\n                    </table>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(indexPage);\n\n        const calPage = createPageWithHeader();\n        calPage.innerHTML += `\n            <h1 class=\"page-title\">التقويم الدراسي لعام ${escapeHTML(data.year)}</h1>\n            <div class=\"flex-content\">\n                <div style=\"flex:1; min-height:0; background:white; padding:10px; border-radius:10px; border:1.5px solid var(--border-gold);\">\n                    <div class=\"image-uploader\" style=\"height:100%; max-height: 70vh;\">\n                        <input type=\"file\" accept=\"image/*\" onchange=\"previewLocalImage(this)\">\n                        <div class=\"upload-prompt\">انقر لإدراج صورة<br>التقويم الدراسي</div>\n                        <img src=\"\" alt=\"Calendar\" style=\"max-height:100%; object-fit:contain;\">\n                    </div>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(calPage);\n\n        const introPage = createPageWithHeader();\n        introPage.innerHTML += `\n            <h1 class=\"page-title\">المقدمة</h1>\n            <div class=\"flex-content\">\n                <div class=\"content-box\">\n                    <p style=\"white-space:pre-line;\">${escapeHTML(data.introduction)}</p>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(introPage);\n\n        const defPage = createPageWithHeader();\n        let charsList = '';\n        data.definition.characteristics.forEach(c => charsList += `<li>${escapeHTML(c)}</li>`);\n        defPage.innerHTML += `\n            <h1 class=\"page-title\">تعريف النشاط اللاصفي</h1>\n            <div class=\"flex-content\">\n                <div class=\"content-box\">\n                    <span class=\"highlight-title\">مفهوم النشاط:</span>\n                    <p>${escapeHTML(data.definition.concept)}</p>\n                </div>\n                <div class=\"content-box\">\n                    <span class=\"highlight-title\">خصائصه:</span>\n                    <ul style=\"margin-right:20px;\">${charsList}</ul>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(defPage);\n\n        const impPage = createPageWithHeader();\n        let impItems = '';\n        data.importance.forEach((item, i) => impItems += `<p><strong>${i+1}. ${escapeHTML(item)}</strong></p>`);\n        impPage.innerHTML += `\n            <h1 class=\"page-title\">أهمية النشاط اللاصفي</h1>\n            <div class=\"flex-content\">\n                <div class=\"content-box\">${impItems}</div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(impPage);\n\n        const visPage = createPageWithHeader();\n        visPage.innerHTML += `\n            <h1 class=\"page-title\">الرؤية والرسالة والقيم</h1>\n            <div class=\"flex-content\">\n                <div class=\"content-box\" style=\"border-right:10px solid var(--primary-purple);\">\n                    <span class=\"highlight-title\">رؤيتنا:</span>\n                    <p>${escapeHTML(data.vision)}</p>\n                </div>\n                <div class=\"content-box\" style=\"border-right:10px solid var(--accent-green);\">\n                    <span class=\"highlight-title\">رسالتنا:</span>\n                    <p>${escapeHTML(data.mission)}</p>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(visPage);\n\n        const goalPage = createPageWithHeader();\n        goalPage.innerHTML += `\n            <h1 class=\"page-title\">الهدف العام للأنشطة</h1>\n            <div class=\"flex-content\" style=\"justify-content:center;\">\n                <div class=\"content-box\" style=\"text-align:center; background:#fdfbf7; border:1.5px solid var(--border-gold);\">\n                    <p style=\"font-size:20px; font-weight:bold; color:var(--primary-purple);\">${escapeHTML(data.generalGoal)}</p>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(goalPage);\n\n        const progPage = createPageWithHeader();\n        let progRows = '';\n        data.programs.forEach(p => progRows += `<tr><td>${escapeHTML(p.field)}</td><td>${escapeHTML(p.examples)}</td></tr>`);\n        progPage.innerHTML += `\n            <h1 class=\"page-title\">برامج الأنشطة اللاصفية</h1>\n            <div class=\"flex-content\">\n                <div class=\"content-box\" style=\"padding:0;\">\n                    <table>\n                        <thead><tr><th style=\"width:30%;\">المجال</th><th>أمثلة للبرامج</th></tr></thead>\n                        <tbody>${progRows}</tbody>\n                    </table>\n                </div>\n            </div>\n            <div class=\"page-footer\"><div class=\"footer-border\"></div></div>\n        `;\n        container.appendChild(progPage);\n\n        const sepPage = document.createElement('div');\n        sepPage.className = 'page separator-page';\n        sepPage.innerHTML = `\n            <div class=\"separator-inner\">\n                <h1 style=\"color:var(--border-gold); font-size:40px; margin-bottom:15px;\">خطة الأنشطة اللاصفية</h1>\n                <h2 style=\"font-size:24px;\">${escapeHTML(data.semester)} - ${escapeHTML(data.year)}</h2>\n            </div>\n        `;\n        container.appendChild(sepPage);\n\n        data.weeks.forEach(item => {\n            const weekPage = createPageWithHeader();\n            const rows = item.rows || [\n                { program: \"\", duration: \"\", implementer: \"\" },\n                { program: \"\", duration: \"\", implementer: \"\" },\n                { program: \"\", duration: \"\", implementer: \"\" }\n            ];\n            let tablesHtml = '';\n            dayNames.forEach((dayName, index) => {\n                const date = item.days[index] || '';\n                let firstRowCells = '';\n                let otherRowsHtml = '';\n\n                rows.forEach((r, ri) => {\n                    const label = ri === 0 ? \"الاصطفاف\" : (ri === 1 ? \"الفسحة\" : \"الصلاة\");\n                    const cells = `<td class=\"activity-type-cell\">${label}</td><td>${escapeHTML(r.program) || '&nbsp;'}</td><td>${escapeHTML(r.duration) || '&nbsp;'}</td><td>${escapeHTML(r.implementer) || '&nbsp;'}</td>`;\n\n                    if (ri === 0) {\n                        firstRowCells = cells;\n                    } else {\n                        otherRowsHtml += `<tr>${cells}</tr>`;\n                    }\n                });\n\n                tablesHtml += `\n                <table style=\"margin-bottom:6px;\">\n                    <thead>\n                        <tr><th style=\"width:15%;\">اليوم</th><th style=\"width:15%;\">وقت التنفيذ</th><th style=\"width:40%;\">اسم البرنامج</th><th style=\"width:15%;\">مدة التنفيذ</th><th style=\"width:15%;\">اسم المنفذة</th></tr>\n                    </thead>\n                    <tbody>\n                        <tr>\n                            <td rowspan=\"3\" class=\"day-header-cell\">${dayName}<br><span style=\"font-size:10px; font-weight:normal;\">${date}</span></td>\n                            ${firstRowCells}\n                        </tr>\n                        ${otherRowsHtml}\n                    </tbody>\n                </table>`;\n            });\n            weekPage.innerHTML += `\n                <div class=\"week-info-bar\">\n                    <div class=\"week-info-date\">من ${escapeHTML(item.range.split(' إلى ')[0])} هـ إلى ${escapeHTML(item.range.split(' إلى ')[1])} هـ</div>\n                    <div class=\"week-info-label\">الأسبوع ${escapeHTML(item.week)}</div>\n                </div>\n                <div class=\"flex-content\">\n                    ${tablesHtml}\n                </div>\n                <div class=\"page-footer\">\n                    <div class=\"signature-section\">\n                        <div>رائدة النشاط: ${escapeHTML(data.activityLeader)}</div>\n                        <div>مديرة المدرسة: ${escapeHTML(data.principal)}</div>\n                    </div>\n                    <div class=\"footer-border\"></div>\n                </div>\n            `;\n            container.appendChild(weekPage);\n        });\n    }\n\n    function createPageWithHeader() {\n        const page = document.createElement('div');\n        page.className = 'page';\n        const headerDiv = document.createElement('div');\n        headerDiv.className = 'global-header-display';\n        page.appendChild(headerDiv);\n        return page;\n    }\n\n    function escapeHTML(str) {\n        return String(str).replace(/[&<>\"]/g, function(m) {\n            if (m === '&') return '&amp;';\n            if (m === '<') return '&lt;';\n            if (m === '>') return '&gt;';\n            if (m === '\"') return '&quot;';\n            return m;\n        });\n    }\n\n    window.uploadGlobalHeader = function(input) {\n        const file = input.files[0];\n        if (!file) return;\n        const reader = new FileReader();\n        reader.onload = function(e) {\n            const imgUrl = e.target.result;\n            const displays = document.querySelectorAll('.global-header-display');\n            displays.forEach(div => {\n                div.style.display = 'block';\n                div.innerHTML = `<img src=\"${imgUrl}\" alt=\"Header\">`;\n            });\n            document.getElementById('global-prompt').innerText = \"تم تحديث الترويسة\";\n        };\n        reader.readAsDataURL(file);\n    };\n\n    window.previewLocalImage = function(input) {\n        const file = input.files[0];\n        if (!file) return;\n        const reader = new FileReader();\n        const uploader = input.parentElement;\n        const img = uploader.querySelector('img');\n        const prompt = uploader.querySelector('.upload-prompt');\n        reader.onload = function(e) {\n            img.src = e.target.result;\n            img.style.display = 'block';\n            if (prompt) prompt.style.display = 'none';\n        };\n        reader.readAsDataURL(file);\n    };\n\n    document.getElementById('applyBtn').addEventListener('click', () => {\n        try {\n            const raw = jsonArea.value.trim();\n            if (!raw) return;\n            const data = JSON.parse(raw);\n            buildReport(data);\n            jsonArea.value = JSON.stringify(data, null, 2);\n        } catch (e) {\n            alert('❌ خطأ في JSON: ' + e.message);\n        }\n    });\n\n    document.getElementById('loadDefaultBtn').addEventListener('click', () => {\n        jsonArea.value = JSON.stringify(DEFAULT_JSON, null, 2);\n        buildReport(DEFAULT_JSON);\n    });\n\n    window.addEventListener('DOMContentLoaded', () => {\n        jsonArea.value = JSON.stringify(DEFAULT_JSON, null, 2);\n        buildReport(DEFAULT_JSON);\n    });\n</script>\n</body>\n</html>",
